{
	"name": "@apple-pie/slice",
	"version": "0.1.20",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.mjs",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		},
		"./hooks": {
			"types": "./dist/types/hooks/index.d.ts",
			"import": "./dist/esm/hooks.mjs",
			"require": "./dist/cjs/hooks.js"
		},
		"./hooks/*": {
			"types": "./dist/types/hooks/*/*.d.ts",
			"import": "./dist/esm/hooks/*.mjs",
			"require": "./dist/cjs/hooks/*.js"
		},
		"./providers": {
			"types": "./dist/types/providers/index.d.ts",
			"import": "./dist/esm/providers.mjs",
			"require": "./dist/cjs/providers.js"
		},
		"./providers/*": {
			"types": "./dist/types/providers/*.d.ts",
			"import": "./dist/esm/providers/*.mjs",
			"require": "./dist/cjs/providers/*.js"
		},
		"./stores": {
			"types": "./dist/types/stores/index.d.ts",
			"import": "./dist/esm/stores.mjs",
			"require": "./dist/cjs/stores.js"
		},
		"./stores/*": {
			"types": "./dist/types/stores/*/index.d.ts",
			"import": "./dist/esm/stores/*.mjs",
			"require": "./dist/cjs/stores/*.js"
		},
		"./workers/*": {
			"import": "./dist/esm/workers/*.mjs",
			"require": "./dist/cjs/workers/*.js"
		},
		"./theme": {
			"types": "./dist/types/theme/index.d.ts",
			"import": "./dist/esm/theme.mjs",
			"require": "./dist/cjs/theme.js"
		},
		"./theme/colors": {
			"types": "./dist/types/theme/colors/colors.d.ts",
			"import": "./dist/esm/theme/colors.mjs",
			"require": "./dist/cjs/theme/colors.js"
		},
		"./theme/corners": {
			"types": "./dist/types/theme/corners/corners.d.ts",
			"import": "./dist/esm/theme/corners.mjs",
			"require": "./dist/cjs/theme/corners.js"
		},
		"./theme/elevations": {
			"types": "./dist/types/theme/elevations/elevations.d.ts",
			"import": "./dist/esm/theme/elevations.mjs",
			"require": "./dist/cjs/theme/elevations.js"
		},
		"./theme/motion": {
			"types": "./dist/types/theme/motion/motion.d.ts",
			"import": "./dist/esm/theme/motion.mjs",
			"require": "./dist/cjs/theme/motion.js"
		},
		"./theme/type": {
			"types": "./dist/types/theme/type/type.d.ts",
			"import": "./dist/esm/theme/type.mjs",
			"require": "./dist/cjs/theme/type.js"
		},
		"./theme/themes": {
			"types": "./dist/types/theme/themes.d.ts",
			"import": "./dist/esm/theme/themes.mjs",
			"require": "./dist/cjs/theme/themes.js"
		},
		"./utils": {
			"types": "./dist/types/utils/index.d.ts",
			"import": "./dist/esm/utils/index.mjs",
			"require": "./dist/cjs/utils/index.js"
		},
		"./utils/objects": {
			"types": "./dist/types/utils/objects/index.d.ts",
			"import": "./dist/esm/utils/objects/index.mjs",
			"require": "./dist/cjs/utils/objects/index.js"
		},
		"./components/*": {
			"types": "./dist/types/components/*/index.d.ts",
			"import": "./dist/esm/components/*/index.mjs",
			"require": "./dist/cjs/components/*/index.js"
		}
	},
	"files": ["dist", "README.md", "scripts/copy-assets.mjs"],
	"sideEffects": ["**/*.css"],
	"scripts": {
		"lint": "biome format --write . && biome check .",
		"lint:fix": "biome format --write . && biome check --write .",
		"format": "biome format --write .",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"benchmark": "vitest run --project benchmarks benchmarks/run-with-report.bench.ts",
		"benchmark:raw": "vitest bench --project benchmarks --run",
		"benchmark:watch": "vitest bench --project benchmarks",
		"benchmark:ui": "vitest bench --project benchmarks --ui",
		"prebuild": "rm -rf dist",
		"build": "NODE_ENV=production rollup -c --bundleConfigAsCjs && tsc -p tsconfig.build.json && ./scripts/copy-css.sh",
		"build:min": "MINIFY=true NODE_ENV=production rollup -c --bundleConfigAsCjs && tsc -p tsconfig.build.json && ./scripts/copy-css.sh",
		"dev": "vite",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"types": "dist/types/index.d.ts",
	"description": "",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@chromatic-com/storybook": "^5.0.1",
		"@csstools/postcss-global-data": "^3.1.0",
		"@rollup/plugin-alias": "^5.1.1",
		"@rollup/plugin-babel": "^6.0.4",
		"@rollup/plugin-commonjs": "^28.0.2",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.1.2",
		"@rollup/plugin-url": "^8.0.2",
		"@storybook/addon-a11y": "^10.2.12",
		"@storybook/addon-docs": "^10.2.13",
		"@storybook/addon-onboarding": "^10.2.9",
		"@storybook/addon-vitest": "^10.2.12",
		"@storybook/react": "^10.2.9",
		"@storybook/react-vite": "^10.2.9",
		"@svgr/rollup": "^8.1.0",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.10.8",
		"@types/react": "^19.0.7",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"happy-dom": "^20.7.0",
		"jsdom": "^28.1.0",
		"playwright": "^1.58.2",
		"postcss-custom-media": "^11.0.6",
		"rollup": "^4.32.0",
		"rollup-plugin-json": "^4.0.0",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"rollup-plugin-postcss": "^4.0.2",
		"rollup-plugin-strip-code": "^0.2.8",
		"rollup-plugin-visualizer": "^7.0.1",
		"storybook": "^10.2.9",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.11",
		"vite-plugin-svgr": "^4.3.0",
		"vitest": "^4.0.18",
		"zustand": "^5.0.0"
	},
	"peerDependencies": {
		"motion": "^11.15.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"zustand": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"zustand": {
			"optional": true
		}
	}
}
