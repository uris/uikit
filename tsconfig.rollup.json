{
	"compilerOptions": {
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"strictPropertyInitialization": true,
		"noImplicitThis": true,
		"alwaysStrict": true,
		"baseUrl": "./",
		"target": "ES6",
		"lib": ["ESNext", "DOM"],
		"module": "ESNext",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"moduleResolution": "Bundler",
		"resolveJsonModule": true
	},
	"include": ["src/**/*"],
	"exclude": [
		"src/theme/_helpers/**",
		"src/theme/_helpers/*.ts",
		"src/theme/_helpers/*.tsx",
		"src/theme/_helpers/*.css",
		"**/*.stories.ts",
		"**/*.stories.tsx",
		"src/stories/**"
	]
}
